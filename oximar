<!DOCTYPE html>
<html>
<head>
  <title>Oximar</title>

  <style>
    body {
      font-family: Arial;
      background: #f4f6f9;
      padding: 20px;
      text-align: center;
    }

    h1 {
      color: #2c3e50;
    }

    input, button {
      padding: 10px;
      margin: 5px;
      border-radius: 8px;
      border: 1px solid #ccc;
    }

    button {
      background: #3498db;
      color: white;
      cursor: pointer;
      border: none;
    }

    button:hover {
      background: #2980b9;
    }

    table {
      margin: 20px auto;
      border-collapse: collapse;
      width: 90%;
      background: white;
      border-radius: 10px;
      overflow: hidden;
    }

    th {
      background: #3498db;
      color: white;
      padding: 10px;
    }

    td {
      padding: 10px;
      border-bottom: 1px solid #ddd;
    }

    .vencendo {
      background-color: #ffeaa7;
    }

    .vencido {
      background-color: #ff7675;
      color: white;
    }

    .btn-excluir {
      background: #e74c3c;
    }
  </style>
</head>

<body>

  <h1>Oximar - Cadastro</h1>

  <input type="text" id="nome" placeholder="Nome do cliente">
  <input type="text" id="produto" placeholder="Produto">
  <input type="date" id="validade">

  <button onclick="salvar()">Salvar</button>

  <h3>Clientes cadastrados</h3>

  <table>
    <thead>
      <tr>
        <th>Cliente</th>
        <th>Produto</th>
        <th>Validade</th>
        <th>Ação</th>
      </tr>
    </thead>
    <tbody id="lista"></tbody>
  </table>

  <script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
    import { getDatabase, ref, set, onValue, remove } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js";

    const firebaseConfig = {
      apiKey: "SUA_API_KEY",
      authDomain: "SEU_PROJETO.firebaseapp.com",
      databaseURL: "https://SEU_PROJETO-default-rtdb.firebaseio.com",
      projectId: "SEU_PROJETO",
      storageBucket: "SEU_PROJETO.appspot.com",
      messagingSenderId: "XXXX",
      appId: "XXXX"
    };

    const app = initializeApp(firebaseConfig);
    const db = getDatabase(app);

    // SALVAR
    window.salvar = function() {
      let nome = document.getElementById("nome").value;
      let produto = document.getElementById("produto").value;
      let validade = document.getElementById("validade").value;

      set(ref(db, 'clientes/' + nome), {
        nome,
        produto,
        validade
      });

      alert("Salvo!");
    }

    // EXCLUIR
    window.excluir = function(nome) {
      remove(ref(db, 'clientes/' + nome));
    }

    // MOSTRAR
    const lista = document.getElementById("lista");

    onValue(ref(db, 'clientes'), (snapshot) => {
      lista.innerHTML = "";

      snapshot.forEach((child) => {
        let dados = child.val();

        let hoje = new Date();
        let validade = new Date(dados.validade);

        let diff = (validade - hoje) / (1000 * 60 * 60 * 24);

        let classe = "";
        if (diff < 0) {
          classe = "vencido";
        } else if (diff <= 7) {
          classe = "vencendo";
        }

        let tr = document.createElement("tr");
        tr.className = classe;

        tr.innerHTML = `
          <td>${dados.nome}</td>
          <td>${dados.produto}</td>
          <td>${dados.validade}</td>
          <td>
            <button class="btn-excluir" onclick="excluir('${dados.nome}')">Excluir</button>
          </td>
        `;

        lista.appendChild(tr);
      });
    });
  </script>

</body>
</html>
